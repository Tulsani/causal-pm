{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causal-pm.local/schemas/event.schema.json",
  "title": "Causal PM Event",
  "type": "object",
  "required": ["event_id", "session_id", "visitor_id", "timestamp", "type", "page", "context"],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "session_id": {
      "type": "string"
    },
    "visitor_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "type": {
      "type": "string",
      "enum": ["page_view", "click", "hover", "scroll", "input", "submit", "route_change", "custom"]
    },
    "page": {
      "type": "object",
      "required": ["url", "path", "title"],
      "properties": {
        "url": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "title": {
          "type": "string"
        }
      }
    },
    "element": {
      "type": "object",
      "properties": {
        "fingerprint": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "dom_path": {
          "type": "string"
        },
        "attributes": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "context": {
      "type": "object",
      "properties": {
        "viewport": {
          "type": "object"
        },
        "device": {
          "type": "object"
        },
        "experiment": {
          "type": "object"
        },
        "metadata": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}

