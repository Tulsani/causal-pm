{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://causal-pm.local/schemas/graph.schema.json",
  "title": "Causal PM Graph",
  "type": "object",
  "required": ["graph_id", "nodes", "edges"],
  "properties": {
    "graph_id": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "label"],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["page", "route", "element", "action", "state", "outcome"]
          },
          "label": {
            "type": "string"
          },
          "properties": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "kind"],
        "properties": {
          "source": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": ["contains", "precedes", "enables", "influences", "causes_candidate"]
          },
          "weight": {
            "type": "number"
          },
          "evidence": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

